---
interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'zh';
}
const { title, description = 'Rao Xu personal website and SAP Basis blog.', lang = 'en' } = Astro.props;
const isZh = lang === 'zh';
const nav = isZh
  ? { about: '关于', writing: '写作', projects: '项目', contact: '联系' }
  : { about: 'About', writing: 'Writing', projects: 'Projects', contact: 'Contact' };
const switchHref = isZh ? '/?lang=en' : '/?lang=zh';
const switchLabel = isZh ? 'EN' : '中文';
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111111" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      :root{--bg:#111111;--bg-soft:#171717;--panel:rgba(255,248,240,.045);--text:#f5efe6;--muted:#c7beb2;--line:rgba(245,239,230,.12);--gold:#c6a972;--rose:#b67c6a;--ivory:#f8f1e7;--shadow:0 24px 80px rgba(0,0,0,.28);--radius:24px;--max:1120px}
      *{box-sizing:border-box} html{scroll-behavior:smooth} body{margin:0;font-family:Inter,ui-sans-serif,system-ui,sans-serif;color:var(--text);background:radial-gradient(circle at 15% 10%,rgba(198,169,114,.10),transparent 24%),radial-gradient(circle at 85% 18%,rgba(182,124,106,.10),transparent 24%),linear-gradient(180deg,#111111 0%,#161413 100%);line-height:1.7;letter-spacing:.01em}
      body:before{content:"";position:fixed;inset:0;pointer-events:none;background:linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);background-size:36px 36px;mask-image:radial-gradient(circle at center,black 35%,transparent 80%);opacity:.12}
      a{color:inherit;text-decoration:none}.container{width:min(var(--max),calc(100% - 40px));margin:0 auto}.nav{position:sticky;top:0;z-index:20;backdrop-filter:blur(14px);background:rgba(17,17,17,.72);border-bottom:1px solid rgba(255,255,255,.05)}.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 0}.logo{font-family:"Cormorant Garamond",serif;font-size:28px;font-weight:600;letter-spacing:.06em}.logo span{color:var(--gold)}.menu{display:flex;gap:18px;align-items:center}.menu a{color:var(--muted);font-size:14px}.menu a:hover{color:var(--ivory)}
      .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 16px;border-radius:999px;border:1px solid var(--line);transition:.2s ease;font-weight:600;background:transparent}.btn:hover{transform:translateY(-1px);border-color:rgba(198,169,114,.4)}.btn.primary{background:linear-gradient(135deg,rgba(198,169,114,.95),rgba(182,124,106,.92));color:#181412;border:none;box-shadow:0 12px 32px rgba(198,169,114,.18)}.btn.lang{padding:8px 14px;font-size:13px;color:var(--gold)}
      .hero{padding:72px 0 42px}.eyebrow{display:inline-block;padding:8px 14px;border:1px solid var(--line);border-radius:999px;color:var(--gold);font-size:12px;letter-spacing:.12em;text-transform:uppercase;margin-bottom:18px;background:rgba(255,255,255,.03)} h1,h2,h3,h4{font-family:"Cormorant Garamond",serif}.page-title{font-size:clamp(34px,6vw,58px);line-height:1.02;margin:0 0 14px;font-weight:600}.section-title{font-size:36px;font-weight:600;margin:0 0 10px}.lead{max-width:760px;font-size:17px;color:var(--muted);margin-bottom:24px}
      .stats,.grid-3,.grid-2,.grid-1{display:grid;gap:16px}.stats{grid-template-columns:repeat(4,minmax(0,1fr));margin-top:24px}.grid-3{grid-template-columns:repeat(3,minmax(0,1fr))}.grid-2{grid-template-columns:repeat(2,minmax(0,1fr))}.grid-1{grid-template-columns:1fr}.stat,.card,.timeline-item,.footer-box,.quote,.post{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);backdrop-filter:blur(10px)}.card,.post,.timeline-item,.stat{padding:24px}.card h3,.post h3{margin:0 0 10px;font-size:26px;font-weight:600;color:var(--ivory)}.card p,.post p,.section-lead,.muted,.stat span{color:var(--muted)}.stat strong{display:block;font-family:"Cormorant Garamond",serif;font-size:28px;font-weight:600;margin-bottom:8px;color:var(--ivory)}
      .tag-list{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px}.tag{padding:8px 12px;border-radius:999px;border:1px solid var(--line);color:var(--gold);font-size:12px;letter-spacing:.08em;text-transform:uppercase;background:rgba(255,255,255,.025)}.footer{padding:40px 0 68px;color:var(--muted)}.footer-box{display:flex;justify-content:space-between;align-items:center;gap:18px;flex-wrap:wrap;padding:24px}.prose{max-width:760px}.prose p,.prose li{color:var(--muted);font-size:17px}.prose h1,.prose h2,.prose h3{color:var(--ivory)}.prose h2{font-size:34px;margin-top:30px}.prose a{color:var(--gold)}
      @media (max-width:900px){.stats,.grid-3,.grid-2{grid-template-columns:1fr}.menu{display:none}.hero{padding-top:56px}.section-title{font-size:30px}.card h3,.post h3{font-size:24px}}
    </style>
  </head>
  <body>
    <nav class="nav">
      <div class="container nav-inner">
        <a class="logo" href={isZh ? '/?lang=zh' : '/'}>Rao<span>Xu</span></a>
        <div class="menu">
          <a href={isZh ? '/about/?lang=zh' : '/about/'}>{nav.about}</a>
          <a href={isZh ? '/writing/?lang=zh' : '/writing/'}>{nav.writing}</a>
          <a href={isZh ? '/projects/?lang=zh' : '/projects/'}>{nav.projects}</a>
          <a href={isZh ? '/contact/?lang=zh' : '/contact/'}>{nav.contact}</a>
          <a class="btn lang" href={switchHref}>{switchLabel}</a>
        </div>
      </div>
    </nav>
    <slot />
  </body>
</html>
