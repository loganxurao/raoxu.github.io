---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const isZh = lang === 'zh';
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === lang)).sort((a,b)=> b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
---
<BaseLayout title={isZh ? '写作 | Rao Xu' : 'Writing | Rao Xu'} description={isZh ? 'Rao Xu 的 SAP Basis 文章、笔记与技术写作。' : 'SAP Basis articles, notes and technical writing by Rao Xu.'} lang={lang}>
  <main class="container hero">
    <h1 class="page-title">{isZh ? '写作' : 'Writing'}</h1>
    <p class="lead">{isZh ? '这里是真正的博客文章列表页，用于持续发布 SAP Basis 相关文章。' : 'A real blog index for SAP Basis writing: operations notes, migration summaries and monitoring practices.'}</p>
    <div class="grid-1">
      {posts.map((post) => (
        <article class="post">
          <h3><a href={`/writing/${post.slug}/?lang=${lang}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="tag-list">
            {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
