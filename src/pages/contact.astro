---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const isZh = lang === 'zh';
---
<BaseLayout title={isZh ? '联系 | Rao Xu' : 'Contact | Rao Xu'} description={isZh ? '联系 Rao Xu，围绕 SAP Basis 交流与合作。' : 'Contact Rao Xu for SAP Basis communication and collaboration.'} lang={lang}>
  <main class="container hero prose">
    <h1 class="page-title">{isZh ? '联系' : 'Contact'}</h1>
    <p>{isZh ? '如果你想交流 SAP Basis 运维、技术问题，或未来合作方向，可以通过下面方式联系我。' : 'If you want to discuss SAP Basis operations, technical exchange, or future collaboration, you can reach me here.'}</p>
    <div class="card">
      <h3>Email</h3>
      <p><a href="mailto:xu.rao@lilve.com">xu.rao@lilve.com</a></p>
    </div>
  </main>
</BaseLayout>
