---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const isZh = lang === 'zh';
---
<BaseLayout title={isZh ? '关于 | Rao Xu' : 'About | Rao Xu'} description={isZh ? '关于 Rao Xu，SAP Basis 顾问。' : 'About Rao Xu, SAP Basis consultant.'} lang={lang}>
  <main class="container hero prose">
    <h1 class="page-title">{isZh ? '关于我' : 'About Rao Xu'}</h1>
    <p>{isZh ? '我从事 SAP Basis，关注 SAP 系统的稳定运行、可维护架构与长期技术可靠性。这个网站用于呈现我的专业方向与技术写作。' : 'I work in SAP Basis and focus on stable SAP operations, maintainable landscapes and long-term technical reliability. This site presents my professional profile and technical writing.'}</p>
    <div class="grid-2">
      <article class="card"><h3>{isZh ? '关注点' : 'Focus'}</h3><p>{isZh ? 'SAP landscape 管理、监控、迁移、备份恢复。' : 'SAP landscape administration, monitoring, migration, backup and recovery.'}</p></article>
      <article class="card"><h3>{isZh ? '风格' : 'Style'}</h3><p>{isZh ? '冷静、直接、结构化、执行优先。' : 'Calm, direct, structured and execution-first.'}</p></article>
    </div>
  </main>
</BaseLayout>
