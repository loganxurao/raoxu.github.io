---
import BaseLayout from '../layouts/BaseLayout.astro';
const lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const isZh = lang === 'zh';
---
<BaseLayout title={isZh ? '项目 | Rao Xu' : 'Projects | Rao Xu'} description={isZh ? 'SAP Basis 项目方向与经验归档。' : 'Selected SAP Basis project directions and experience archive.'} lang={lang}>
  <main class="container hero">
    <h1 class="page-title">{isZh ? '项目' : 'Projects'}</h1>
    <p class="lead">{isZh ? '这一页用于放置 SAP Basis 项目摘要与经验归档。即使部分细节匿名，也能清楚展示我负责过哪类工作。' : 'This page is for selected SAP Basis project snapshots and experience archives. Even with anonymized details, the structure shows the kinds of work I handle.'}</p>
    <div class="grid-2">
      <article class="card"><h3>{isZh ? '系统管理' : 'SAP System Administration'}</h3><p>{isZh ? '安装、配置、实例处理与日常管理。' : 'Installation, configuration and routine administration.'}</p></article>
      <article class="card"><h3>{isZh ? '监控与排障' : 'Monitoring & Troubleshooting'}</h3><p>{isZh ? '问题发现、运行检查、性能复盘与排障流程。' : 'Issue detection, performance review and troubleshooting workflow.'}</p></article>
      <article class="card"><h3>{isZh ? '升级与迁移' : 'Upgrade & Migration'}</h3><p>{isZh ? '升级准备、迁移支持与变更后验证。' : 'Upgrade preparation, migration support and post-change validation.'}</p></article>
      <article class="card"><h3>{isZh ? '备份与恢复' : 'Backup & Recovery'}</h3><p>{isZh ? '恢复规划与业务连续性文档。' : 'Recovery planning and documentation for business continuity.'}</p></article>
    </div>
  </main>
</BaseLayout>
