---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const lang = Astro.url.searchParams.get('lang') === 'zh' ? 'zh' : 'en';
const isZh = lang === 'zh';
const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === lang)).sort((a,b)=> b.data.pubDate.valueOf()-a.data.pubDate.valueOf()).slice(0,3);
---
<BaseLayout title={isZh ? 'Rao Xu | SAP Basis 顾问' : 'Rao Xu | SAP Basis Consultant'} description={isZh ? 'Rao Xu 的 SAP Basis 双语博客与个人网站。' : 'Bilingual personal website and blog for SAP Basis operations, monitoring and migration.'} lang={lang}>
  <main class="container">
    <section class="hero">
      <div class="eyebrow">SAP BASIS · INFRASTRUCTURE · OPERATIONS</div>
      <h1 class="page-title">{isZh ? '构建稳定、安全、可扩展的 SAP 系统环境。' : 'Building stable, secure and scalable SAP landscapes.'}</h1>
      <p class="lead">{isZh ? '我是 Rao Xu，专注 SAP Basis、系统管理、监控、迁移、备份恢复与运行稳定性。这个网站现在是一个真正可维护的博客系统，用来持续沉淀中英文技术内容。' : 'I’m Rao Xu, a SAP Basis consultant focused on SAP administration, monitoring, migration, backup and system reliability. This site is now a maintainable blog system built for long-term bilingual technical publishing.'}</p>
      <div class="grid-2">
        <article class="card"><h3>{isZh ? '专业主页' : 'Professional Homepage'}</h3><p>{isZh ? '清楚呈现专业方向、能力范围与联系方式。' : 'A concise profile with clear focus, expertise and contact.'}</p></article>
        <article class="card"><h3>{isZh ? '博客系统' : 'Blog System'}</h3><p>{isZh ? '基于 Markdown 的文章系统，适合长期写作与归档。' : 'Markdown-based publishing with article pages and future-ready structure.'}</p></article>
      </div>
    </section>

    <section>
      <h2 class="section-title">{isZh ? '最新文章' : 'Latest Writing'}</h2>
      <div class="grid-1">
        {posts.map((post) => (
          <article class="post">
            <h3><a href={`/writing/${post.slug}/?lang=${lang}`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="tag-list">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
  <footer class="footer"><div class="container footer-box"><div><strong style="font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--ivory)">Rao Xu</strong><br/><span>{isZh ? 'SAP Basis 顾问 · 中英文博客系统' : 'SAP Basis Consultant · bilingual blog system'}</span></div><a class="btn primary" href={isZh ? '/writing/?lang=zh' : '/writing/'}>{isZh ? '进入写作' : 'Go to Writing'}</a></div></footer>
</BaseLayout>
